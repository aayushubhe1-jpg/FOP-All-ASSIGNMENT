#include <stdio.h>
#include <math.h>

// Function to calculate factorial
long long factorial(int n) {
    long long fact = 1;
    for(int i = 1; i <= n; i++) {
        fact *= i;
    }
    return fact;
}

int main() {
    int n, i;
    float x, sum = 0;

    printf("Enter value of x (in radians): ");
    scanf("%f", &x);

    printf("Enter number of terms: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        int power = 2*i + 1;
        float term = pow(x, power) / factorial(power);

        if(i % 2 == 0)
            sum += term;
        else
            sum -= term;
    }

    printf("\nSum of sine series = %f\n", sum);

    return 0;
}
