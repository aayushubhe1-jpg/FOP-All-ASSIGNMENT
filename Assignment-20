#include <stdio.h>

// Function without pointers
void swap(int a, int b) {
    int temp;
    temp = a;
    a = b;
    b = temp;

    printf("Inside function (without pointers): a = %d, b = %d\n", a, b);
}

// Function using pointers
void swapPtr(int *a, int *b) {
    int temp;
    temp = *a;
    *a = *b;
    *b = temp;
}

int main() {
    int x, y;

    // User input
    printf("Enter two numbers:\n");
    scanf("%d %d", &x, &y);

    printf("\nBefore swap: x = %d, y = %d\n", x, y);

    // Without pointers
    swap(x, y);
    printf("After swap (without pointers): x = %d, y = %d\n", x, y);

    // With pointers
    swapPtr(&x, &y);
    printf("After swap (with pointers): x = %d, y = %d\n", x, y);

    return 0;
}
